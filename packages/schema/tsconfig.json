{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "declaration": true,
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "vitest"]
  },
  "include": ["src"],
  "exclude": ["lib"]
}
