{
  "name": "@webda/hawk",
  "version": "4.0.0-beta.1",
  "description": "Implements Hawk on webda",
  "keywords": [
    "hawk",
    "webda"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "webda build",
    "build:watch": "webda build --watch",
    "pretest": "npm run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "dependencies": {
    "@webda/core": "workspace:*",
    "hawk": "^9.0.2",
    "is-in-subnet": "^4.0.1",
    "jsonwebtoken": "^9.0.3"
  },
  "files": [
    "lib",
    "test",
    "webda.module.json"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "webda": {
    "namespace": "Webda"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/compiler": "workspace:^",
    "@webda/shell": "workspace:*",
    "jscodeshift": "^17.3.0",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/shell"
    ]
  },
  "license": "LGPL-3.0-only"
}
