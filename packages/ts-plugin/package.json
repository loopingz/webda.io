{
  "name": "@webda/ts-plugin",
  "version": "4.0.0-beta.1",
  "description": "TypeScript Language Service Plugin + build-time transformer for Webda models",
  "keywords": [
    "typescript",
    "plugin",
    "language-service",
    "webda"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    },
    "./transform": {
      "types": "./lib/transform.d.ts",
      "import": "./lib/transform.js",
      "require": "./lib/transform.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "pretest": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "ts-patch": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "ts-patch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vite": "^6.0.0",
    "skott": "^0.35.8"
  },
  "files": [
    "lib"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "LGPL-3.0-only"
}