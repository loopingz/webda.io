{
  "name": "@webda/aws",
  "version": "4.0.0-beta.1",
  "description": "Webda AWS Services implementation",
  "main": "lib/index.js",
  "scripts": {
    "build": "webdac",
    "build:watch": "webdac --watch",
    "pretest": "webdac",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "c8 mocha",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopingz/webda.io.git"
  },
  "keywords": [
    "webda",
    "modda"
  ],
  "files": [
    "lib",
    "webda.module.json",
    "webda.shell.json",
    "package.json"
  ],
  "author": "loopingz",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/loopingz/webda.io/issues"
  },
  "homepage": "https://github.com/loopingz/webda.io#readme",
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1019.0",
    "@aws-sdk/client-api-gateway": "^3.1019.0",
    "@aws-sdk/client-cloudformation": "^3.1019.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1019.0",
    "@aws-sdk/client-dynamodb": "^3.1019.0",
    "@aws-sdk/client-ec2": "^3.1019.0",
    "@aws-sdk/client-lambda": "^3.1019.0",
    "@aws-sdk/client-route-53": "^3.1019.0",
    "@aws-sdk/client-s3": "^3.1019.0",
    "@aws-sdk/client-secrets-manager": "^3.1019.0",
    "@aws-sdk/client-sqs": "^3.1019.0",
    "@aws-sdk/client-sts": "^3.1019.0",
    "@aws-sdk/lib-dynamodb": "^3.1019.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@types/json-schema": "^7.0.15",
    "@types/mocha": "^10.0.10",
    "@webda/async": "workspace:*",
    "@webda/core": "workspace:*",
    "@webda/ql": "workspace:*",
    "@webda/workout": "workspace:*",
    "bluebird": "^3.7.2",
    "commitlint": "^20.5.0",
    "cookie": "^1.1.1",
    "glob": "^13.0.6",
    "iam-policy-optimizer": "^1.2.0",
    "mime-types": "^3.0.2",
    "yaml": "^2.8.3"
  },
  "c8": {
    "report-dir": "./reports",
    "reporter": [
      "html",
      "lcov",
      "json",
      "text"
    ],
    "exclude": [
      "**/*.spec.ts",
      "test/**/*"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "25.5.0",
    "@webda/compiler": "workspace:^",
    "@webda/shell": "workspace:*",
    "aws-sdk-client-mock": "^4.1.0",
    "jscodeshift": "^17.3.0",
    "node-fetch": "^3.3.2",
    "sinon": "^21.0.3",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/shell"
    ]
  }
}