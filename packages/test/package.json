{
  "name": "@webda/test",
  "version": "4.0.0",
  "description": "Test for NodeJS projects",
  "keywords": [],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "exports": {
    "default": "./lib/index.js"
  },
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "pretest": "tsc",
    "precommit": "eslint --fix && prettier --write src/**/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest debug",
    "test:coverage": "vitest run --coverage",
    "test:mocha": "mocha --node-option import=tsx 'src/**/*.spec.ts'",
    "test:jest": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:bun": "bun test",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "dependencies": {
    "@webda/decorators": "workspace:^",
    "@webda/workout": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "jscodeshift": "^17.3.0",
    "mocha": "^10.2.0",
    "jest": "^30.3.0",
    "vitest": "^4.1.2",
    "vite": "^6.0.0",
    "skott": "^0.35.8",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0"
  },
  "peerDependenciesMeta": {
    "mocha": {
      "required": false
    },
    "jest": {
      "required": false
    },
    "vitest": {
      "required": false
    }
  },
  "files": [
    "lib"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "LGPL-3.0-only"
}
