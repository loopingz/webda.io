{
  "name": "@webda/core",
  "version": "4.0.0-beta.1",
  "description": "Expose API with Lambda",
  "keywords": [
    "aws",
    "lamda",
    "api gateway"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./lib/*": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js"
    },
    "./lib/*.js": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "webda": "./lib/bin/launcher.js"
  },
  "scripts": {
    "build": "webdac build",
    "build:watch": "webdac build --watch",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:debug": "vitest --inspect-brk --test-timeout=0 --no-file-parallelism",
    "test:seq": "vitest run --no-file-parallelism"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15",
    "@webda/cache": "workspace:^",
    "@webda/decorators": "workspace:^",
    "@webda/models": "workspace:^",
    "@webda/ql": "workspace:*",
    "@webda/utils": "workspace:^",
    "@webda/workout": "workspace:*",
    "accept-language": "^3.0.20",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "antlr4ts": "0.5.0-alpha.4",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "dateformat": "^5.0.3",
    "deepmerge-ts": "^7.1.5",
    "email-templates": "^13.0.1",
    "glob": "^13.0.6",
    "global": "^4.4.0",
    "is-in-subnet": "^4.0.1",
    "json-schema": "^0.4.0",
    "jsonc-parser": "^3.3.1",
    "jsondiffpatch": "^0.7.3",
    "jsonpath": "^1.3.0",
    "jsonwebtoken": "^9.0.3",
    "merge": "^2.1.1",
    "mime-types": "^3.0.2",
    "mustache": "^4.2.0",
    "node-cron": "^4.2.1",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^8.0.4",
    "openapi-types": "^12.1.3",
    "pem-jwk": "^2.0.0",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.17.2",
    "semver": "^7.7.4",
    "stream-buffers": "^3.0.3",
    "ts-json-schema-generator": "^2.9.0",
    "ts-method-cache": "^3.3.1",
    "uri-templates": "^0.2.0",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@webda/compiler": "workspace:^",
    "@webda/tsc-esm": "workspace:*",
    "@webda/test": "workspace:^",
    "axios": "^1.14.0",
    "c8": "^11.0.0",
    "eslint": "^10.1.0",
    "fs-extra": "^11.3.4",
    "jest": "^30.3.0",
    "jscodeshift": "^17.3.0",
    "prettier": "^3.8.1",
    "sinon": "^21.0.3",
    "skott": "^0.35.8",
    "source-map-support": "^0.5.21",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "ws": "^8.20.0",
    "vite": "^6.0.0"
  },
  "files": [
    "lib",
    "test",
    "webda.module.json"
  ],
  "c8": {
    "report-dir": "./reports",
    "reporter": [
      "html",
      "lcov",
      "json"
    ],
    "exclude": [
      "hooks.mjs",
      "hooks-register.mjs",
      "lib/**/*",
      "src/test.ts",
      "**/*.spec.ts",
      "test/**/*",
      "*/stores/webdaql/WebdaQL*"
    ],
    "excludeNodeModules": true
  },
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/tsc-esm",
      "@webda/workout"
    ]
  },
  "webda": {
    "namespace": "Webda",
    "capabilities": {
      "router": "Webda/Router",
      "rest-domain": "Webda/RESTOperationsTransport",
      "http-server": "Webda/HttpServer"
    }
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "LGPL-3.0-only"
}