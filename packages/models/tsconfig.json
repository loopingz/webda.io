{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "declarationMap": true,
    "useDefineForClassFields": false,
    "strictPropertyInitialization": false,
    "plugins": [
      {
        "name": "@webda/ts-plugin"
      }
    ],
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "**/node_modules",
    "src/**/*.spec.ts"
  ]
}
