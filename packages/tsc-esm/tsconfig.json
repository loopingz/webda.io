{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "es2022",
      "DOM",
      "ESNext.Decorators"
    ],
    "module": "preserve",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": false,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "declarationMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "**/node_modules"
  ]
}
