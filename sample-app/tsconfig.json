{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "outDir": "./lib",
    "rootDir": "./src",
    "strict": false,
    "sourceMap": true,
    "declaration": true,
    "experimentalDecorators": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declarationMap": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*",
    ".webda.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/*.spec.ts"
  ],
  "ts-node": {
    "compilerOptions": {
      "experimentalDecorators": false
    }
  }
}
