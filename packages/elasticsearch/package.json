{
  "name": "@webda/elasticsearch",
  "version": "4.0.0-beta.1",
  "description": "Webda ElasticSearch implementation",
  "main": "lib/index.js",
  "scripts": {
    "build": "webda build",
    "build:watch": "webda build --watch",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "pretest": "npm run build",
    "test": "vitest run",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopingz/webda.io.git"
  },
  "keywords": [
    "webda",
    "modda"
  ],
  "files": [
    "lib",
    "webda.module.json",
    "package.json"
  ],
  "author": "loopingz",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/loopingz/webda.io/issues"
  },
  "homepage": "https://github.com/loopingz/webda.io#readme",
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@webda/core": "workspace:*",
    "dateformat": "^5.0.3",
    "yaml": "^2.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/compiler": "workspace:^",
    "@webda/shell": "workspace:*",
    "jscodeshift": "^17.3.0",
    "sinon": "^21.0.3",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/shell"
    ]
  }
}
