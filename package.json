{
  "name": "webda.io",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "@commitlint/config-conventional": "^19.1.0",
    "@types/json-schema": "^7.0.8",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "commitlint": "^19.2.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "gh-pages": "^6.0.0",
    "glob": "^10.0.0",
    "husky": "^9.0.6",
    "jsonpath": "^1.1.1",
    "merge-stream": "^2.0.0",
    "mocha": ">=9.0.2",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "sinon": "^19.0.2",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.6.0"
  },
  "author": "loopingz",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/loopingz/webda.io/issues"
  },
  "homepage": "https://github.com/loopingz/webda.io#readme",
  "repository": "git://github.com/loopingz/webda.io.git",
  "scripts": {
    "build": "pnpm -r run build",
    "build:ci": "pnpm --filter @webda/sample-app run build",
    "test": "pnpm -r --filter=!@webda/sample-app run test",
    "new-version": "pnpm run build && pnpm -r exec pnpm version --no-git-tag-version",
    "new-module": "pnpm webda init webda:module",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "publish:all": "pnpm -r publish",
    "docs": "cd docs && pnpm run update:typedoc && pnpm run build && echo 'webda.io' > build/CNAME",
    "docs:publish": "pnpm run docs && gh-pages -t -d docs/build",
    "deps:graph": "pnpm -r run deps:graph",
    "init": "husky"
  },
  "pnpm": {
    "overrides": {
      "whatwg-url": "^14.0.0"
    }
  },
  "webda": {
    "randomLink": "./test.json",
    "namespace": "Webda"
  },
  "type": "module",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
