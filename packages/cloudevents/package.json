{
  "name": "@webda/cloudevents",
  "version": "4.0.0-beta.2",
  "description": "Discovery and Subscriptions for CloudEvents",
  "keywords": [
    "cloudevents",
    "webda"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "tsc-esm",
    "build:watch": "tsc-esm --watch",
    "grammar": "antlr4ts -visitor src/stores/webdaql/WebdaQLLexer.g4 src/stores/webdaql/WebdaQLParser.g4 && pnpm run lint:fix",
    "pretest": "npm run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:bun": "bun test --coverage",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "dependencies": {
    "antlr4ts": "0.5.0-alpha.4",
    "cloudevents": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/compiler": "workspace:^",
    "@webda/tsc-esm": "workspace:*",
    "jscodeshift": "^17.3.0",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "files": [
    "lib"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "LGPL-3.0-only"
}