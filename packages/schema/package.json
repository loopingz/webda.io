{
  "name": "@webda/schema",
  "version": "0.6.0",
  "description": "TypeScript language-service powered JSON Schema generator",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "type": "module",
  "bin": {
    "webda-schema-generator": "lib/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "generate": "node lib/cli.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "verify": "vitest run",
    "test:watch": "vitest",
    "presnapshots": "pnpm build",
    "snapshots": "tsx test/update-snapshots.ts",
    "test:fixture": "FIXTURE=$FIXTURE vitest run test/schema.test.ts",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts"
  },
  "keywords": [
    "typescript",
    "json-schema",
    "language-service"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "25.5.0",
    "jsondiffpatch": "^0.7.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "vite": "^6.0.0",
    "skott": "^0.35.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}