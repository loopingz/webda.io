{
  "name": "@webda/compiler",
  "version": "4.0.0-beta.2",
  "description": "Expose API with Lambda",
  "keywords": [
    "aws",
    "lamda",
    "api gateway"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "bin": {
    "webdac": "./lib/shell.js"
  },
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "tsc-esm",
    "build:watch": "tsc-esm --watch",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "schema": "ts-json-schema-generator --path src/definition.ts -f ./tsconfig.json --type 'WebdaModule' -o ./webda.module.schema.json",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@phenomnomnominal/tsquery": "^6.1.4",
    "@types/json-schema": "^7.0.15",
    "@webda/schema": "workspace:^",
    "@webda/ts-plugin": "workspace:^",
    "@webda/utils": "workspace:^",
    "@webda/workout": "workspace:*",
    "accept-language": "^3.0.20",
    "diff": "^8.0.4",
    "ts-morph": "^27.0.2",
    "yargs": "^18.0.0",
    "yoctocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/test": "workspace:*",
    "@webda/tsc-esm": "workspace:*",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1",
    "skott": "^0.35.8",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "lib"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "LGPL-3.0-only"
}