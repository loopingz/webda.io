{
  "name": "@webda/postgres",
  "version": "4.0.0-beta.1",
  "description": "Implements Postgres on webda",
  "keywords": [
    "postgres",
    "webda"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "webdac build",
    "build:watch": "webdac build --watch",
    "pretest": "npm run build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "dependencies": {
    "@webda/core": "workspace:*",
    "@webda/ql": "workspace:*",
    "@webda/utils": "workspace:*",
    "@webda/workout": "workspace:*",
    "pg": "^8.20.0"
  },
  "files": [
    "lib",
    "test",
    "webda.module.json"
  ],
  "homepage": "https://webda.io",
  "publishConfig": {
    "access": "public"
  },
  "webda": {
    "namespace": "Webda"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.2",
    "@webda/compiler": "workspace:^",
    "@webda/test": "workspace:*",
    "@webda/tsc-esm": "workspace:*",
    "jscodeshift": "^17.3.0",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/core"
    ]
  },
  "license": "LGPL-3.0-only"
}
