{
  "name": "@webda/gcp",
  "version": "4.0.0-beta.2",
  "description": "Webda GCP Services implementation",
  "main": "lib/index.js",
  "scripts": {
    "build": "webdac",
    "build:watch": "webda build --watch",
    "pretest": "npm run build",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/loopingz/webda.io.git"
  },
  "keywords": [
    "webda",
    "modda"
  ],
  "files": [
    "lib",
    "webda.module.json",
    "package.json"
  ],
  "author": "abalam666",
  "license": "LGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/loopingz/webda.io/issues"
  },
  "homepage": "https://github.com/loopingz/webda.io#readme",
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@google-cloud/kms": "^5.4.0",
    "@google-cloud/pubsub": "^5.3.0",
    "@google-cloud/storage": "~7.19.0",
    "@webda/core": "workspace:*",
    "@webda/ql": "workspace:*",
    "mime-types": "^3.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/async": "workspace:*",
    "@webda/compiler": "workspace:^",
    "@webda/test": "workspace:*",
    "jscodeshift": "^17.3.0",
    "sinon": "^21.0.3",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/shell"
    ]
  }
}