{
  "name": "@webda/shell",
  "version": "4.0.0-beta.1",
  "description": "Deploy a Webda app or configure it",
  "keywords": [
    "aws",
    "lamda",
    "api gateway"
  ],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "repository": "git://github.com/loopingz/webda.io.git",
  "bin": {
    "webdashell": "./lib/bin/webda.js"
  },
  "files": [
    "lib",
    "webda.module.json"
  ],
  "scripts": {
    "build": "webdac build && chmod +x ./lib/bin/webda.js",
    "build:watch": "webdac build --watch",
    "pretest": "npm run build",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@phenomnomnominal/tsquery": "^6.1.4",
    "@webda/compiler": "workspace:^",
    "@webda/core": "workspace:*",
    "@webda/kubernetes": "workspace:*",
    "@webda/workout": "workspace:*",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "cookie": "^1.1.1",
    "dateformat": "^5.0.3",
    "fs-extra": "^11.3.4",
    "generator-webda": "^1.5.2",
    "glob": "^13.0.6",
    "is-in-subnet": "^4.0.1",
    "json-schema": "^0.4.0",
    "jsonpath": "^1.3.0",
    "merge": "^2.1.1",
    "mime-types": "^3.0.2",
    "semver": "^7.7.4",
    "semver-intersect": "^1.5.0",
    "ts-json-schema-generator": "^2.9.0",
    "typescript": "^6.0.2",
    "unzipper": "^0.12.3",
    "yaml": "^2.8.3",
    "yargs": "^18.0.0",
    "yeoman-environment": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/yargs": "^17.0.35",
    "@webda/compiler": "workspace:*",
    "@webda/test": "workspace:*",
    "csstype": "^3.2.3",
    "jscodeshift": "^17.3.0",
    "node-fetch": "^3.3.2",
    "sinon": "^21.0.3",
    "skott": "^0.35.8",
    "tsx": "^4.21.0",
    "vite": "^6.0.0"
  },
  "type": "module",
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/tsc-esm",
      "@webda/kubernetes"
    ]
  },
  "license": "LGPL-3.0-only"
}