{
  "$schema": ".webda/config.schema.json",
  "parameters": {
    "locales": ["en-US"],
    "website": "http://localhost:18080"
  },
  "services": {
    "HttpServer": {
      "type": "Webda/HttpServer",
      "autoTls": true
    },
    "HttpServerH2c": {
      "type": "Webda/HttpServer",
      "port": 50051,
      "h2c": true
    },
    "Publisher": {
      "type": "Publisher"
    },
    "Mailer": {
      "type": "Webda/Mailer"
    },
    "DomainService": {
      "type": "Webda/DomainService"
    },
    "RESTService": {
      "type": "Webda/RESTOperationsTransport"
    },
    "GRPCService": {
      "type": "Webda/GrpcService"
    },
    "GraphQLService": {
      "type": "Webda/GraphQLService"
    },
    "WebUI": {
      "type": "Webda/ResourceService",
      "folder": "./webui",
      "url": "/admin"
    }
  }
}
