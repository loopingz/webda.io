{
  "$schema": "https://webda.io/schemas/webda.module.v4.json",
  "beans": {},
  "deployers": {},
  "moddas": {
    "Webda/ClusterService": {
      "Import": "lib/services/cluster:ClusterService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "keepAlive": {
            "default": 30000,
            "type": "number"
          },
          "pubsub": {
            "default": "PubSub",
            "type": "string"
          },
          "ttl": {
            "default": "twice keepAlive",
            "type": "number"
          },
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "unsyncCodeAlert": {
            "default": false,
            "description": "Display code alert when code is out of sync\n\nCan be disabled by setting it to false - in case different code is subscribing to\nthe same pubsub\n\nIf undefined it will display the alert only once\n\ntrue will force it to display every time",
            "type": "boolean"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "type"
        ],
        "type": "object",
        "title": "ClusterService"
      },
      "Configuration": "lib/services/cluster:ClusterServiceParameters"
    },
    "Webda/EchoService": {
      "Import": "lib/services/echo:EchoService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "description": "Configuration for EchoService — static content served on a fixed route",
        "properties": {
          "mime": {
            "description": "Mime of the result",
            "type": "string"
          },
          "result": {
            "description": "result to write on the url"
          },
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "url": {
            "description": "Url to expose the service",
            "type": "string"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "result",
          "type",
          "url"
        ],
        "type": "object",
        "title": "EchoService"
      },
      "Configuration": "lib/services/echo:EchoServiceParameters"
    },
    "Webda/InvitationService": {
      "Import": "lib/services/invitationservice:InvitationService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "description": "Configuration for the InvitationService — model, storage, and behavior settings",
        "properties": {
          "attribute": {
            "description": "Attribute where to store once the invitation is accepted\n\nIf attribute is __acls, the multiple will be ignored and the storage\nwill be compatible with AclModel\n\nWhere to store within the model User",
            "type": "string"
          },
          "authenticationService": {
            "default": "Authentication",
            "description": "Name of the bean to use for Authentication",
            "type": "string"
          },
          "autoAccept": {
            "default": false,
            "description": "Do not require a validation by the invitee",
            "type": "boolean"
          },
          "invitationStore": {
            "description": "Used to store pending invitation",
            "type": "string"
          },
          "mapAttribute": {
            "description": "Attribute to use for the mapping",
            "type": "string"
          },
          "mapFields": {
            "description": "Fields to duplicate",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "model": {
            "description": "Model to use",
            "type": "string"
          },
          "multiple": {
            "default": true,
            "description": "Define if several invitation can be accepted or just one",
            "type": "boolean"
          },
          "notification": {
            "description": "Email template to send to the user",
            "type": "string"
          },
          "notificationService": {
            "default": "Mailer",
            "description": "Notification service",
            "type": "string"
          },
          "pendingAttribute": {
            "description": "Attribute where to store once the invitation is created and pending\n\nWhere to store within the model Ident and User",
            "type": "string"
          },
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "attribute",
          "invitationStore",
          "mapAttribute",
          "mapFields",
          "model",
          "pendingAttribute",
          "type"
        ],
        "type": "object",
        "title": "InvitationService"
      },
      "Configuration": "lib/services/invitationservice:InvitationParameters"
    },
    "Webda/MigrationStore": {
      "Import": "lib/stores/migration:MigrationStore",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "definitions": {
          "modelAliases": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Model Aliases to allow easier rename of Model",
            "type": "object"
          }
        },
        "description": "Configuration for MigrationStore — specifies the source and destination stores",
        "properties": {
          "additionalModels": {
            "default": [],
            "description": "Additional models\n\nAllow this store to manage other models",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "defaultModel": {
            "default": true,
            "description": "When __type model not found, use the model\nIf strict is setup this parameter is not used",
            "type": "boolean"
          },
          "forceModel": {
            "default": false,
            "description": "If set, Store will ignore the __type",
            "type": "boolean"
          },
          "from": {
            "description": "From store",
            "type": "string"
          },
          "model": {
            "default": "Webda/CoreModel",
            "description": "Webda model to use within the Store",
            "type": "string"
          },
          "modelAliases": {
            "$ref": "#/definitions/modelAliases",
            "description": "Model Aliases to allow easier rename of Model"
          },
          "noCache": {
            "default": false,
            "description": "Disable default memory cache",
            "type": "boolean"
          },
          "slowQueryThreshold": {
            "default": 30000,
            "description": "Slow query threshold",
            "type": "number"
          },
          "strict": {
            "default": false,
            "description": "Allow to load object that does not have the type data\n\nIf set to true, then the Store will only managed the defined _model and no\nmodel extending this one",
            "type": "boolean"
          },
          "to": {
            "description": "To store",
            "type": "string"
          },
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "from",
          "to",
          "type"
        ],
        "type": "object",
        "title": "MigrationStore"
      },
      "Configuration": "lib/stores/migration:MigrationStoreParameters"
    },
    "Webda/PasswordEncryptionService": {
      "Import": "lib/utils/password:PasswordEncryptionService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "PasswordEncryptionService",
        "properties": {
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "Configuration": "node_modules/@webda/core/lib/services/serviceparameters:ServiceParameters"
    },
    "Webda/ProxyService": {
      "Import": "lib/services/proxy:ProxyService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "description": "Proxy to a backend service",
        "properties": {
          "backend": {
            "description": "URL to proxy to",
            "type": "string"
          },
          "proxyHeaders": {
            "default": true,
            "description": "Add X-Forwarded-* headers",
            "type": "boolean"
          },
          "requireAuthentication": {
            "default": false,
            "description": "Helper to refuse any request if user is not auth",
            "type": "boolean"
          },
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "url": {
            "description": "URL to expose",
            "type": "string"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "backend",
          "type"
        ],
        "type": "object",
        "title": "ProxyService"
      },
      "Configuration": "lib/services/proxy:ProxyParameters"
    },
    "Webda/VersionService": {
      "Import": "lib/services/version:VersionService",
      "Schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "description": "Version parameters",
        "properties": {
          "type": {
            "description": "Type of the service",
            "type": "string"
          },
          "url": {
            "default": "/version",
            "type": "string"
          },
          "version": {
            "description": "To force version otherwise would read from package.json",
            "type": "string"
          },
          "openapi": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "required": [
          "type"
        ],
        "type": "object",
        "title": "VersionService"
      },
      "Configuration": "lib/services/version:VersionServiceParameters"
    }
  },
