{
  "name": "@webda/graphql",
  "version": "4.0.0-beta.1",
  "description": "GraphQL endpoint for your Webda Application",
  "main": "lib/index.js",
  "type": "module",
  "scripts": {
    "build": "webda build",
    "pretest": "npm run build",
    "test": "vitest run",
    "new-model": "webda init webda:model",
    "new-service": "webda init webda:service",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "deps:graph": "skott --showCircularDependencies --no-trackTypeOnlyDependencies --displayMode=raw -e .ts",
    "codemod": "jscodeshift --parser=ts --extensions=tsx,ts -t ../codemod/current.mjs src"
  },
  "keywords": [
    "webda-module"
  ],
  "files": [
    "lib",
    "webda.module.json",
    "package.json"
  ],
  "dependencies": {
    "@webda/core": "workspace:*",
    "@webda/ql": "workspace:*",
    "@webda/runtime": "workspace:*",
    "graphql": "^16.13.2",
    "graphql-http": "^1.22.4",
    "graphql-ws": "^6.0.8",
    "json-schema": "^0.4.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@webda/compiler": "workspace:^",
    "c8": "^11.0.0",
    "glob": "^13.0.6",
    "js-beautify": "^1.15.4",
    "jscodeshift": "^17.3.0",
    "prettier": "^3.8.1",
    "skott": "^0.35.8",
    "source-map-support": "^0.5.21",
    "vite": "^6.0.0"
  },
  "webda": {
    "namespace": "Webda"
  },
  "bugs": {
    "url": "https://github.com/loopingz/webda.io/issues"
  },
  "homepage": "https://github.com/loopingz/webda.io#readme",
  "repository": "git://github.com/loopingz/webda.io.git",
  "license": "LGPL-3.0-only",
  "nx": {
    "implicitDependencies": [
      "@webda/core",
      "@webda/shell"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}