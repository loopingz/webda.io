{
  "name": "@webda/debug",
  "version": "4.0.0-beta.1",
  "description": "Development debug server for Webda applications",
  "keywords": ["webda", "debug"],
  "author": "Remi Cattiau <remi@cattiau.com>",
  "repository": "git://github.com/loopingz/webda.io.git",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "scripts": {
    "build": "webdac build",
    "build:watch": "webdac build --watch",
    "pretest": "npm run build",
    "format": "prettier --check src/**/*",
    "format:fix": "prettier --write src/**/*",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:debug": "vitest debug",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "terminal-kit": "^3.1.2",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@webda/core": "^4.0.0-beta.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.2",
    "@webda/compiler": "workspace:^",
    "@webda/core": "workspace:^",
    "@webda/tsc-esm": "workspace:*",
    "@webda/test": "workspace:*",
    "jscodeshift": "^17.3.0",
    "typescript": "6.0.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "files": ["lib", "webui"],
  "homepage": "https://webda.io",
  "publishConfig": { "access": "public" },
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "license": "LGPL-3.0-only"
}
